APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
FILESYSTEM_UPLOADS_DISK=public
FILESYSTEM_TEMPORARY_URL_MINUTES=1440
FILESYSTEM_S3_THROW=true
FILESYSTEM_S3_REPORT=true
MEDIA_IMAGE_QUALITY=76
MEDIA_THUMBNAIL_WIDTH=300
MEDIA_CARD_WIDTH=600
MEDIA_GALLERY_WIDTH=1200
MEDIA_ORIGINAL_MAX_WIDTH=2000
MEDIA_LOGO_THUMBNAIL_WIDTH=160
MEDIA_LOGO_CARD_WIDTH=320
MEDIA_LOGO_GALLERY_WIDTH=640
MEDIA_LOGO_ORIGINAL_MAX_WIDTH=1200
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-north-1
AWS_BUCKET=s-tech-max-store-assets
AWS_URL=https://assets.stechmax.com
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PAYMENT_URL=https://api.paystack.co

GEOLOCATION_ENABLED=true
GEOLOCATION_ENDPOINT=https://ipapi.co/{ip}/json/
GEOLOCATION_TIMEOUT=2
GEOLOCATION_REVERSE_GEOCODE_ENDPOINT=https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat={lat}&lon={lng}
GEOLOCATION_DEFAULT_COUNTRY_CODE=NG
GEOLOCATION_DEFAULT_STATE="Lagos State"
GEOLOCATION_DEFAULT_CITY=Lagos
GEOLOCATION_REVERSE_MATCH_DISTANCE_KM=75
GEOLOCATION_BROWSER_MAX_ACCURACY_METERS=25000
GEOLOCATION_BROWSER_LOCATION_TTL_MINUTES=180

